<h1>Your Shopping Cart</h1>

<% if session[:cart].blank? %>
  <p>Your cart is empty.</p>
<% else %>
  <ul>
    <% @products.each do |product| %>
      <li>
        <%= product.name %> - 
        <%= number_to_currency(product.price) %><br>
        Quantity: 
        <%= form_with url: update_cart_path(product.id), method: :post, local: true do %>
          <%= number_field_tag :quantity, session[:cart][product.id.to_s], min: 1 %>
          <%= submit_tag "Update" %>
        <% end %>
        <%= button_to "Remove", remove_from_cart_path(product.id), method: :post %>
      </li>
    <% end %>
  </ul>

  <br>

  <%= link_to "Proceed to Checkout", checkout_path %> |
  <%= link_to "Back to Products", store_index_path %>
<% end %>
