<!DOCTYPE html>
<html>
  <head>
    <title>Red Heart Fashion Hub</title>

    <!-- Meta Tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Rails Security Tags -->
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Rails Assets -->
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>

    <!-- Custom Styles -->
    <style>
      .flash-message {
        background-color: #d4edda;
        color: #155724;
        padding: 10px;
        margin: 20px auto;
        width: 90%;
        border-radius: 5px;
        border: 1px solid #c3e6cb;
        text-align: center;
      }

      .flash-error {
        background-color: #f8d7da;
        color: #721c24;
        padding: 10px;
        margin: 20px auto;
        width: 90%;
        border-radius: 5px;
        border: 1px solid #f5c6cb;
        text-align: center;
      }

      footer {
        background-color: #f8f9fa;
        padding: 20px;
        text-align: center;
        margin-top: 40px;
        border-top: 1px solid #ddd;
      }
    </style>
  </head>

  <body>
    <!-- Header -->
    <header class="bg-light py-4 border-bottom">
      <div class="container text-center">
        <h1 class="mb-3">Red Heart Fashion Hub</h1>
        <div class="d-flex justify-content-center gap-3">
          <%= link_to "Home", root_path, class: "btn btn-primary btn-sm" %>
          <%= link_to "Products", store_index_path, class: "btn btn-success btn-sm" %>
          <%= link_to "Cart", cart_path, class: "btn btn-danger btn-sm" %>
        </div>
      </div>
    </header>

    <!-- Flash Messages (if not admin) -->
    <% unless controller_path.starts_with?("admin/") %>
      <% if flash[:notice] %>
        <div class="flash-message"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="flash-error"><%= flash[:alert] %></div>
      <% end %>
    <% end %>

    <!-- Main Content -->
    <main class="container my-4">
      <%= yield %>
    </main>

    <!-- Footer -->
    <%= render 'shared/footer' %>
  </body>
</html>
