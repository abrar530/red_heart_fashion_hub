<h1 class="text-center mt-4 mb-4">Your Cart</h1>

<% if @products.any? %>
  <%= form_with url: update_cart_quantities_path, method: :post, local: true do %>
    <table class="table table-bordered table-striped text-center align-middle">
      <thead class="table-dark">
        <tr>
          <th>Image</th>
          <th>Product</th>
          <th>Quantity</th>
          <th>Price</th>
          <th>Subtotal</th>
          <th>Remove</th>
        </tr>
      </thead>
      <tbody>
        <% @products.each do |product| %>
          <tr>
            <td>
              <% if product.image.attached? %>
                <%= image_tag url_for(product.image), size: "80x80", alt: product.name %>
              <% else %>
                <span class="text-muted">No image</span>
              <% end %>
            </td>
            <td class="fw-bold"><%= product.name %></td>
            <td>
              <%= number_field_tag "quantities[#{product.id}]", @cart[product.id.to_s], min: 1, class: "form-control text-center" %>
            </td>
            <td>$<%= number_with_precision(product.price, precision: 2) %></td>
            <td>$<%= number_with_precision(product.price * @cart[product.id.to_s].to_i, precision: 2) %></td>
            <td>
              <%= button_to "Remove", remove_from_cart_path(product), method: :post, class: "btn btn-danger", data: { confirm: "Are you sure you want to remove this item?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="d-flex justify-content-between align-items-center mt-4">
      <%= submit_tag "Update Cart", class: "btn btn-primary" %>
      <h4 class="mb-0">
        <strong>Total: $<%= number_with_precision(@products.sum { |product| product.price * @cart[product.id.to_s].to_i }, precision: 2) %></strong>
      </h4>
    </div>
  <% end %>

  <div class="text-center mt-5">
    <%= link_to "Checkout", checkout_path, class: "btn btn-success btn-lg" %>
  </div>
<% else %>
  <p class="text-center">Your cart is empty.</p>
<% end %>
