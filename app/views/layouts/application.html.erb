<!DOCTYPE html>
<html>
  <head>
    <title>RedHeartFashionHub</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>

    <style>
      .product p {
        margin-bottom: 6px;
      }
      .product {
        margin-bottom: 25px;
      }
      .flash-message {
        background-color: #d4edda;
        color: #155724;
        padding: 10px;
        margin: 10px auto;
        width: 90%;
        border-radius: 5px;
        border: 1px solid #c3e6cb;
        text-align: center;
      }
    </style>
  </head>

  <body>
    <%= render 'shared/header' %>

    <% unless controller_path.starts_with?("admin/") %>
      <% if flash[:notice] %>
        <div class="flash-message"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="flash-message" style="background-color: #f8d7da; color: #721c24; border-color: #f5c6cb;">
          <%= flash[:alert] %>
        </div>
      <% end %>
    <% end %>

    <%= yield %>

    <%= render 'shared/footer' %>
  </body>
</html>

